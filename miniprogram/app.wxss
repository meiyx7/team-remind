/* app.wxss 全局样式 + 设计令牌 */

page {
  /* 品牌色 */
  --color-brand: #10b981;
  --color-brand-light: #34d399;
  --color-brand-lightest: #d1fae5;
  --color-brand-dark: #059669;
  --color-brand-darker: #047857;

  /* 状态色 */
  --state-success: #10b981;
  --state-warning: #f59e0b;
  --state-error: #ef4444;
  --state-info: #3b82f6;

  /* 灰阶 */
  --color-gray-100: #f3f4f6;
  --color-gray-200: #e5e7eb;
  --color-gray-300: #d1d5db;
  --color-gray-400: #9ca3af;

  /* 背景 */
  --bg-primary: #ffffff;
  --bg-secondary: #f9fafb;
  --bg-tertiary: #f3f4f6;

  /* 文本 */
  --text-primary: #0f172a;
  --text-secondary: #475569;
  --text-tertiary: #94a3b8;
  --text-inverse: #ffffff;

  /* 边框 */
  --border-light: #e5e7eb;
  --border-default: #d1d5db;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 4rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.05);
  --shadow-lg: 0 8rpx 24rpx rgba(0,0,0,0.10);
  --shadow-elevated: 0 12rpx 32rpx rgba(0,0,0,0.16);

  /* 间距令牌（4 的倍数体系） */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  /* 字号令牌 */
  --fs-xs: 22rpx;
  --fs-sm: 26rpx;
  --fs-base: 30rpx;
  --fs-md: 32rpx;
  --fs-lg: 36rpx;
  --fs-xl: 40rpx;
  --fs-2xl: 48rpx;

  /* 内容区底部留白：tabbar 高度(100rpx) + 安全区 */
  --tabbar-height: 100rpx;

  /* 导航栏背景（带半透明 + 模糊） */
  --nav-bg: rgba(255, 255, 255, 0.95);

  background-color: var(--bg-secondary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Noto Sans SC', 'Microsoft YaHei', sans-serif;
  font-size: var(--fs-base);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 暗色模式：在根容器加 .theme-dark 类即可让所有 CSS 变量级联覆盖 */
.theme-dark {
  --color-brand: #34d399;
  --color-brand-light: #6ee7b7;
  --color-brand-lightest: #064e3b;
  --color-brand-dark: #34d399;
  --color-brand-darker: #6ee7b7;

  --color-gray-100: #1e293b;
  --color-gray-200: #334155;
  --color-gray-300: #475569;
  --color-gray-400: #64748b;

  --bg-primary: #1e293b;
  --bg-secondary: #0f172a;
  --bg-tertiary: #334155;

  --text-primary: #f1f5f9;
  --text-secondary: #cbd5e1;
  --text-tertiary: #64748b;
  --text-inverse: #0f172a;

  --border-light: #334155;
  --border-default: #475569;

  --shadow-sm: 0 2rpx 4rpx rgba(0,0,0,0.30);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.35);
  --shadow-lg: 0 8rpx 24rpx rgba(0,0,0,0.45);
  --shadow-elevated: 0 12rpx 32rpx rgba(0,0,0,0.50);

  --nav-bg: rgba(15, 23, 42, 0.92);
}

view, text, image, input, textarea, button, scroll-view {
  box-sizing: border-box;
}

/* 通用容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--bg-secondary);
}

/* 卡片基础样式 */
.card {
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

/* 主按钮 */
.btn-primary {
  background: var(--color-brand);
  color: var(--text-inverse);
  border-radius: var(--radius-full);
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: var(--fs-md);
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.88;
  transform: scale(0.99);
}

.btn-primary[disabled] {
  background: var(--color-gray-300);
  color: var(--text-inverse);
  opacity: 0.7;
}

/* 次按钮（描边） */
.btn-ghost {
  background: var(--bg-primary);
  color: var(--color-brand-dark);
  border: 1rpx solid var(--color-brand);
  border-radius: var(--radius-md);
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: var(--fs-sm);
  font-weight: 500;
}

.btn-ghost::after {
  border: none;
}

/* flex 工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

/* 文本工具 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-brand { color: var(--color-brand); }
.text-warning { color: var(--state-warning); }
.text-error { color: var(--state-error); }
.text-success { color: var(--state-success); }

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.truncate {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* 安全区底部填充 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用按压反馈 */
.tap-feedback:active {
  background-color: var(--bg-secondary);
}
