<!-- custom-tab-bar/index.wxml -->
<view class="tabbar {{themeClass}}">
  <view
    class="tab-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="{{selected === index ? item.activeIcon : item.icon}}" />
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
<view class="tabbar-safe {{themeClass}}"></view>
