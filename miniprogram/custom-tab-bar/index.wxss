/* custom-tab-bar/index.wxss */
.tabbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 100rpx;
  background: var(--bg-primary);
  border-top: 1rpx solid var(--border-light);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.tab-item.active .tab-text {
  color: var(--color-brand);
}

/* 图标使用纯 CSS 绘制，避免依赖图片资源 */

/* 首页图标 - 房子 */
.icon-home {
  width: 36rpx;
  height: 32rpx;
  position: relative;
}
.icon-home::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 18rpx solid var(--text-tertiary);
}
.icon-home::after {
  content: '';
  position: absolute;
  left: 6rpx;
  bottom: 0;
  width: 24rpx;
  height: 16rpx;
  border: 4rpx solid var(--text-tertiary);
  border-top: none;
  border-radius: 2rpx;
}
.icon-home.on::before {
  border-bottom-color: var(--color-brand);
}
.icon-home.on::after {
  border-color: var(--color-brand);
}

/* 团队图标 - 人群 */
.icon-team {
  width: 40rpx;
  height: 32rpx;
  position: relative;
}
.icon-team::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
  box-shadow: -12rpx 2rpx 0 -2rpx var(--text-tertiary), 12rpx 2rpx 0 -2rpx var(--text-tertiary);
}
.icon-team::after {
  content: '';
  position: absolute;
  left: 4rpx;
  bottom: 0;
  width: 32rpx;
  height: 14rpx;
  border: 4rpx solid var(--text-tertiary);
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
}
.icon-team.on::before {
  background: var(--color-brand);
  box-shadow: -12rpx 2rpx 0 -2rpx var(--color-brand), 12rpx 2rpx 0 -2rpx var(--color-brand);
}
.icon-team.on::after {
  border-color: var(--color-brand);
}

/* 待办图标 - 勾选框 */
.icon-todo {
  width: 36rpx;
  height: 32rpx;
  position: relative;
}
.icon-todo::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--text-tertiary);
  border-radius: 6rpx;
}
.icon-todo::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 10rpx;
  width: 14rpx;
  height: 8rpx;
  border-left: 4rpx solid var(--text-tertiary);
  border-bottom: 4rpx solid var(--text-tertiary);
  transform: rotate(-45deg);
}
.icon-todo.on::before {
  border-color: var(--color-brand);
}
.icon-todo.on::after {
  border-left-color: var(--color-brand);
  border-bottom-color: var(--color-brand);
}

/* 我的图标 - 人头像 */
.icon-profile {
  width: 36rpx;
  height: 32rpx;
  position: relative;
}
.icon-profile::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
}
.icon-profile::after {
  content: '';
  position: absolute;
  left: 4rpx;
  bottom: 0;
  width: 28rpx;
  height: 14rpx;
  border: 4rpx solid var(--text-tertiary);
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
}
.icon-profile.on::before {
  background: var(--color-brand);
}
.icon-profile.on::after {
  border-color: var(--color-brand);
}

.tabbar-safe {
  background: var(--bg-primary);
}
