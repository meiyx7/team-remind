<!-- components/todo-card/todo-card.wxml 待办卡片 -->
<view class="todo-card todo-card-{{todo.displayStatus}}" data-id="{{todo.id}}" bindtap="onTap">
  <view
    wx:if="{{showCheck}}"
    class="todo-check {{todo.displayStatus === 'completed' ? 'checked' : ''}}"
    data-id="{{todo.id}}"
    catchtap="onToggle"
  >
    <image wx:if="{{todo.displayStatus === 'completed'}}" class="check-icon" src="{{checkIcon}}" />
  </view>
  <view class="todo-main">
    <view class="todo-title-row">
      <view wx:if="{{todo.priority === 'urgent' && todo.displayStatus !== 'completed'}}" class="urgent-dot"></view>
      <text class="todo-title {{todo.displayStatus === 'completed' ? 'done' : ''}}">{{todo.title}}</text>
    </view>
    <text class="todo-sub">{{subText}}</text>
  </view>
  <view class="todo-right">
    <text wx:if="{{dueText}}" class="todo-due {{todo.displayStatus === 'overdue' ? 'overdue' : ''}}">{{dueText}}</text>
    <text wx:if="{{showAssign}}" class="assign-progress {{todo.assignDone === todo.assignTotal ? 'all-done' : ''}}">{{assignText}}</text>
    <status-badge status="{{todo.displayStatus}}" />
  </view>
</view>
