/* components/state-view/state-view.wxss */
.state-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
}

.state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--border-light);
  border-top-color: var(--color-brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: var(--fs-md);
  color: var(--text-secondary);
  font-weight: 500;
}

.state-desc {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.6;
}

.state-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: var(--color-brand);
  color: var(--text-inverse);
  border-radius: var(--radius-full);
  font-size: var(--fs-sm);
  font-weight: 500;
}

.state-btn:active {
  opacity: 0.88;
}
