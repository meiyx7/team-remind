/* components/nav-bar/nav-bar.wxss */

.nav-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-wrap.solid {
  background: var(--nav-bg);
  backdrop-filter: blur(8px);
  border-bottom: 1rpx solid var(--border-light);
}

.nav-wrap.transparent {
  background: transparent;
}

.nav-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 16rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.nav-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.4rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.back-btn:active {
  background-color: var(--bg-tertiary);
}

.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid var(--text-primary);
  border-bottom: 4rpx solid var(--text-primary);
  transform: rotate(45deg);
  margin-left: 6rpx;
}
