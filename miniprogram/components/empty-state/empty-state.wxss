/* components/empty-state/empty-state.wxss */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 32rpx;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: var(--fs-md);
  color: var(--text-secondary);
  font-weight: 500;
}

.empty-hint {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 12rpx;
  text-align: center;
}

.empty-action {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: var(--color-brand);
  color: var(--text-inverse);
  border-radius: var(--radius-full);
  font-size: var(--fs-sm);
  font-weight: 500;
}

.empty-action:active {
  opacity: 0.88;
}
