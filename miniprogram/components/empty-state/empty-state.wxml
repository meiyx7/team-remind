<!-- components/empty-state/empty-state.wxml 内联空态（紧凑） -->
<view class="empty-state">
  <image class="empty-icon" src="{{icon}}" />
  <text class="empty-text">{{text}}</text>
  <text wx:if="{{hint}}" class="empty-hint">{{hint}}</text>
  <view wx:if="{{actionText}}" class="empty-action" catchtap="onAction">{{actionText}}</view>
</view>
