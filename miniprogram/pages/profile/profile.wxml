<!-- pages/profile/profile.wxml -->
<view class="page-container {{themeClass}}">
  <nav-bar title="我的"></nav-bar>

  <view class="profile-content">
    <!-- 用户卡 -->
    <view class="profile-card">
      <view class="profile-row">
        <avatar text="{{user.avatarChar}}" color="{{user.avatarColor}}" size="lg" />
        <view class="user-info">
          <text class="user-name">{{user.name}}</text>
          <text class="user-email">{{user.email}}</text>
        </view>
      </view>
    </view>

    <!-- 偏好设置 -->
    <view class="settings-group">
      <view class="settings-row">
        <view class="row-left">
          <image class="row-icon" src="{{icons.moon}}" />
          <text class="settings-label">深色模式</text>
        </view>
        <switch checked="{{darkMode}}" bindchange="onToggleDark" color="#10b981" />
      </view>
      <view class="settings-row row-coming" bindtap="onComingSoon">
        <view class="row-left">
          <image class="row-icon" src="{{icons.palette}}" />
          <text class="settings-label">主题换肤</text>
        </view>
        <view class="coming-tag">即将上线</view>
      </view>
      <view class="settings-row row-coming" bindtap="onComingSoon">
        <view class="row-left">
          <image class="row-icon" src="{{icons.bell}}" />
          <text class="settings-label">消息通知</text>
        </view>
        <view class="coming-tag">即将上线</view>
      </view>
    </view>

    <!-- 其他 -->
    <view class="settings-group">
      <view class="settings-row" bindtap="goHelp">
        <view class="row-left">
          <image class="row-icon" src="{{icons.help}}" />
          <text class="settings-label">帮助与反馈</text>
        </view>
        <image class="chevron" src="{{icons.chevron}}" />
      </view>
      <view class="settings-row" bindtap="goAbout">
        <view class="row-left">
          <image class="row-icon" src="{{icons.info}}" />
          <text class="settings-label">关于团队待办</text>
        </view>
        <view class="settings-right">
          <text class="settings-value">v{{version}}</text>
          <image class="chevron" src="{{icons.chevron}}" />
        </view>
      </view>
      <view class="settings-row" bindtap="goAgreement" data-type="user">
        <view class="row-left">
          <image class="row-icon" src="{{icons.fileText}}" />
          <text class="settings-label">用户协议</text>
        </view>
        <image class="chevron" src="{{icons.chevron}}" />
      </view>
      <view class="settings-row" bindtap="goAgreement" data-type="privacy">
        <view class="row-left">
          <image class="row-icon" src="{{icons.shield}}" />
          <text class="settings-label">隐私政策</text>
        </view>
        <image class="chevron" src="{{icons.chevron}}" />
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>
</view>
