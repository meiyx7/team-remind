/* pages/profile/profile.wxss */
.profile-content {
  padding: 32rpx 32rpx calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 48rpx);
}

/* 用户卡 */
.profile-card {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 32rpx;
}

.profile-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
}

.user-email {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 设置分组 */
.settings-group {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  margin-top: 24rpx;
  overflow: hidden;
}

.settings-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.settings-row:last-child {
  border-bottom: none;
}

.settings-row:active {
  background: var(--bg-secondary);
}

/* 即将上线行：不可点视觉 */
.row-coming:active {
  background: transparent;
}

.row-coming .settings-label {
  color: var(--text-tertiary);
}

.row-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.row-icon {
  width: 36rpx;
  height: 36rpx;
}

.settings-label {
  font-size: var(--fs-base);
  color: var(--text-primary);
}

.settings-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.settings-value {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}

.chevron {
  width: 20rpx;
  height: 20rpx;
}

.coming-tag {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  background: var(--bg-tertiary);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

/* 退出登录 */
.logout-btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--bg-primary);
  border: 1rpx solid var(--state-error);
  border-radius: var(--radius-lg);
  color: var(--state-error);
  font-size: var(--fs-md);
  font-weight: 500;
}

.logout-btn:active {
  opacity: 0.85;
}
