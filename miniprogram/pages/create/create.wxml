<!-- pages/create/create.wxml -->
<view class="container">
  <view class="card form-card">
    <!-- 标题 -->
    <view class="form-item">
      <text class="form-label">标题</text>
      <input class="form-input" placeholder="请输入待办标题" value="{{title}}" bindinput="onTitleInput" />
    </view>

    <!-- 描述 -->
    <view class="form-item">
      <text class="form-label">描述</text>
      <textarea class="form-textarea" placeholder="补充说明（选填）" value="{{description}}" bindinput="onDescInput" />
    </view>

    <!-- 指派给 -->
    <view class="form-item">
      <text class="form-label">指派给</text>
      <input class="form-input" placeholder="输入成员名称" value="{{assignee}}" bindinput="onAssigneeInput" />
    </view>

    <!-- 截止日期 -->
    <view class="form-item">
      <text class="form-label">截止日期</text>
      <picker mode="date" value="{{dueDate}}" bindchange="onDateChange">
        <view class="form-input picker-value {{dueDate ? '' : 'placeholder'}}">
          {{dueDate || '选择日期'}}
        </view>
      </picker>
    </view>

    <!-- 优先级 -->
    <view class="form-item">
      <text class="form-label">优先级</text>
      <radio-group bindchange="onPriorityChange">
        <label class="radio-label">
          <radio value="low" checked="{{priority === 'low'}}" /> 低
        </label>
        <label class="radio-label">
          <radio value="normal" checked="{{priority === 'normal'}}" /> 中
        </label>
        <label class="radio-label">
          <radio value="high" checked="{{priority === 'high'}}" /> 高
        </label>
      </radio-group>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-primary submit-btn" bindtap="onSubmit">创建待办</view>
</view>
