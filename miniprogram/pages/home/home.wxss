/* pages/home/home.wxss */

.home-content {
  padding: 16rpx 32rpx calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 160rpx);
}

/* 顶部问候卡 */
.greeting-card {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.greeting-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.greeting-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting-text {
  font-size: var(--fs-xl);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.greeting-date {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}

.today-progress {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.progress-num {
  font-size: var(--fs-lg);
  font-weight: 700;
  color: var(--color-brand-dark);
}

.progress-label {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}

.progress-bar-wrap {
  margin-top: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.progress-bar-track {
  flex: 1;
  height: 12rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-brand);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.progress-rate {
  font-size: var(--fs-sm);
  color: var(--color-brand-dark);
  font-weight: 600;
  min-width: 64rpx;
  text-align: right;
}

/* 时间维度视图切换 */
.range-tabs {
  display: flex;
  flex-direction: row;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 4rpx;
  margin-bottom: 24rpx;
}

.range-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  border-radius: var(--radius-full);
  transition: all 0.15s;
}

.range-tab.active {
  background: var(--bg-primary);
  color: var(--color-brand-dark);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

/* 统计卡网格（4 列，同时作为状态筛选条件） */
.stats-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  transition: all 0.15s;
}

.stat-card:active {
  transform: scale(0.97);
}

.stat-count {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* 选中态：填充对应状态色 */
.stat-card.active {
  border-color: transparent;
}

.stat-card.active .stat-count,
.stat-card.active .stat-label {
  color: var(--text-inverse);
}

.stat-card.stat-in_progress.active { background: var(--state-warning); }
.stat-card.stat-pending.active { background: var(--color-gray-400); }
.stat-card.stat-overdue.active { background: var(--state-error); }
.stat-card.stat-completed.active { background: var(--state-success); }

/* 列表标题 */
.list-header {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.list-count {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}

/* 待办列表 */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 32rpx);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-elevated);
  z-index: 50;
}

.fab:active {
  transform: scale(0.92);
  opacity: 0.92;
}

.fab-icon {
  width: 40rpx;
  height: 40rpx;
}
