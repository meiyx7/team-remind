/* pages/home/home.wxss */

.home-content {
  padding: 24rpx 32rpx calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 160rpx);
}

/* 统计卡网格（4 列，同时作为筛选条件） */
.stats-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  transition: all 0.15s;
}

.stat-card:active {
  transform: scale(0.97);
}

.stat-count {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* 选中态：填充对应状态色 */
.stat-card.active {
  color: var(--text-inverse);
  border-color: transparent;
}

.stat-card.active .stat-count,
.stat-card.active .stat-label {
  color: var(--text-inverse);
}

.stat-card.stat-in_progress.active { background: var(--state-warning); }
.stat-card.stat-pending.active { background: var(--color-gray-400); }
.stat-card.stat-overdue.active { background: var(--state-error); }
.stat-card.stat-completed.active { background: var(--state-success); }

/* 列表标题 */
.list-header {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.list-count {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}

/* 待办列表 */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom) + 32rpx);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-elevated);
  z-index: 50;
}

.fab:active {
  transform: scale(0.92);
  opacity: 0.92;
}

.fab-icon {
  width: 40rpx;
  height: 40rpx;
}
