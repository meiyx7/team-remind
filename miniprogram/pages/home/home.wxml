<!-- pages/home/home.wxml 首页 = 待办（统计卡作为筛选条件） -->
<view class="page-container {{themeClass}}">
  <nav-bar title="团队待办"></nav-bar>

  <view class="home-content">
    <!-- 统计卡：同时作为筛选条件，点击联动下方列表 -->
    <view class="stats-grid">
      <view
        class="stat-card stat-{{item.key}} {{statFilter === item.key ? 'active' : ''}}"
        wx:for="{{stats}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onStatTap"
      >
        <text class="stat-count">{{item.count}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 当前筛选标识 -->
    <view class="list-header">
      <text class="list-title">{{statFilter === 'all' ? '全部待办' : currentLabel}}</text>
      <text class="list-count">{{todos.length}} 项</text>
    </view>

    <!-- 待办列表 -->
    <view wx:if="{{todos.length > 0}}" class="todo-list">
      <todo-card
        wx:for="{{todos}}"
        wx:key="id"
        todo="{{item}}"
        show-check="{{true}}"
        show-team="{{true}}"
        bind:toggle="onToggleTodo"
      />
    </view>

    <!-- 空态 -->
    <empty-state
      wx:else
      text="{{statFilter === 'all' ? '暂无待办' : '该状态下暂无待办'}}"
      hint="{{statFilter === 'all' ? '点击右下角按钮创建第一个待办' : ''}}"
      action-text="{{statFilter === 'all' ? '创建待办' : ''}}"
      bind:action="goCreateTodo"
    />
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="goCreateTodo">
    <image class="fab-icon" src="{{plusIcon}}" />
  </view>
</view>
