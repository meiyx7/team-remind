/* pages/team-list/team-list.wxss */

.team-list-content {
  padding: 32rpx 32rpx 200rpx;
}

/* 左侧创建按钮 */
.create-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid var(--color-brand);
  border-radius: 12rpx;
  color: var(--color-brand-dark);
  font-size: 26rpx;
  font-weight: 500;
}

.create-btn:active {
  background: var(--color-brand-lightest);
}

.plus-sign {
  font-size: 32rpx;
  margin-right: 4rpx;
  line-height: 1;
}

.create-text {
  font-size: 26rpx;
}

/* 搜索框 */
.search-wrap {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  height: 80rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  position: relative;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-circle {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid var(--text-tertiary);
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}

.search-handle {
  width: 12rpx;
  height: 4rpx;
  background: var(--text-tertiary);
  position: absolute;
  bottom: 4rpx;
  right: 0;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-tertiary);
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 36rpx;
  line-height: 1;
}

/* 团队卡片 */
.team-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.team-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-left: 6rpx solid var(--color-brand);
  border-radius: var(--radius-md);
  padding: 32rpx;
}

.team-item:active {
  background: var(--bg-secondary);
}

.team-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.team-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.team-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.5;
}

.team-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  margin-top: 4rpx;
}

.chevron {
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid var(--text-tertiary);
  border-top: 4rpx solid var(--text-tertiary);
  transform: rotate(45deg);
  flex-shrink: 0;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
}
