/* pages/team-list/team-list.wxss */

.team-list-content {
  padding: 32rpx 32rpx 200rpx;
}

/* 左侧创建按钮 */
.create-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid var(--color-brand);
  border-radius: var(--radius-full);
  color: var(--color-brand-dark);
  font-size: 26rpx;
  font-weight: 500;
  gap: 6rpx;
}

.create-btn:active {
  background: var(--color-brand-lightest);
}

.create-icon {
  width: 28rpx;
  height: 28rpx;
}

.create-text {
  font-size: 26rpx;
  line-height: 1;
}

/* 搜索框 */
.search-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  height: 80rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-tertiary);
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.clear-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 团队卡片 */
.team-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.team-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  padding: 32rpx;
}

.team-item:active {
  background: var(--bg-secondary);
}

.team-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.team-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.5;
}

.team-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  margin-top: 4rpx;
}

.chevron-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}
