<!-- pages/team-list/team-list.wxml -->
<view class="page-container {{themeClass}}">
  <nav-bar title="我的团队">
    <view slot="left">
      <view class="create-btn" bindtap="onCreateTeam">
        <image class="create-icon" src="{{plusIcon}}" />
        <text class="create-text">创建团队</text>
      </view>
    </view>
  </nav-bar>

  <view class="team-list-content">
    <!-- 搜索框 -->
    <view class="search-wrap">
      <image class="search-icon" src="{{searchIcon}}" />
      <input
        class="search-input"
        type="text"
        placeholder="搜索团队..."
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearch"
        confirm-type="search"
      />
      <view wx:if="{{keyword}}" class="clear-btn" bindtap="onClear">
        <image class="clear-icon" src="{{clearIcon}}" />
      </view>
    </view>

    <!-- 团队列表 -->
    <view class="team-cards" wx:if="{{teams.length > 0}}">
      <view
        class="team-item"
        wx:for="{{teams}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goTeamDetail"
      >
        <avatar text="{{item.avatarChar}}" color="{{item.avatarColor}}" size="md" />
        <view class="team-main">
          <text class="team-name truncate">{{item.name}}</text>
          <text class="team-desc truncate">{{item.memberCount}} 位成员 · {{item.inProgressCount}} 个待办进行中</text>
        </view>
        <image class="chevron-icon" src="{{chevronIcon}}" />
      </view>
    </view>

    <!-- 空态 -->
    <empty-state
      wx:else
      text="{{keyword ? '未找到匹配的团队' : '还没有团队'}}"
      hint="{{keyword ? '换个关键词试试' : '点击左上角按钮创建第一个团队'}}"
    />
  </view>
</view>
