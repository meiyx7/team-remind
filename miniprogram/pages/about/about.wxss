/* pages/about/about.wxss */
.about-content {
  padding: 32rpx 32rpx 80rpx;
}

.logo-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 64rpx;
}

.logo-circle {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-check {
  width: 64rpx;
  height: 64rpx;
}

.app-name {
  font-size: var(--fs-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.app-version {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.app-slogan {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.about-group {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.about-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.about-row:last-child {
  border-bottom: none;
}

.about-row:active {
  background: var(--bg-secondary);
}

.about-label {
  font-size: var(--fs-base);
  color: var(--text-primary);
}

.chevron {
  width: 20rpx;
  height: 20rpx;
}

.about-desc {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  line-height: 1.7;
  padding: 0 16rpx;
}
