/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: var(--bg-secondary);
  display: flex;
  flex-direction: column;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
}

.top-spacer,
.bottom-spacer {
  flex: 1;
  min-height: 200rpx;
}

/* Logo（扁平单色，无渐变无光晕） */
.logo-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-xl);
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-check {
  width: 80rpx;
  height: 80rpx;
}

.app-name {
  margin-top: 40rpx;
  font-size: 60rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.8rpx;
}

.app-slogan {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.gap {
  height: 80rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--color-brand);
  color: var(--text-inverse);
  border-radius: var(--radius-full);
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  text-align: center;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: var(--color-brand-light);
  color: var(--text-inverse);
  opacity: 0.85;
}

.login-btn:active {
  transform: scale(0.99);
  opacity: 0.92;
}

.agreement {
  margin-top: 32rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.6;
}

.agreement .link {
  color: var(--color-brand-dark);
}
