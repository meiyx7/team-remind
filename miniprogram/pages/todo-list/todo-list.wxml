<!-- pages/todo-list/todo-list.wxml -->
<view class="page-container">
  <nav-bar title="我的待办"></nav-bar>

  <!-- 筛选 Tab -->
  <scroll-view class="filter-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      class="filter-tab {{filter === item.key ? 'active' : ''}}"
      wx:for="{{filters}}"
      wx:key="key"
      data-filter="{{item.key}}"
      bindtap="switchFilter"
    >{{item.label}}</view>
  </scroll-view>

  <view class="todo-list-content">
    <view wx:if="{{todos.length > 0}}" class="todo-cards">
      <view class="todo-card todo-card-{{item.displayStatus}}" wx:for="{{todos}}" wx:key="id">
        <view class="todo-check {{item.displayStatus === 'completed' ? 'checked' : ''}}" data-id="{{item.id}}" catchtap="onToggle">
          <view wx:if="{{item.displayStatus === 'completed'}}" class="check-icon"></view>
        </view>
        <view class="todo-main">
          <text class="todo-title {{item.displayStatus === 'completed' ? 'done' : ''}}">{{item.title}}</text>
          <text class="todo-sub">{{item.teamName}} · {{item.assigneeName}}指派</text>
        </view>
        <view class="todo-right">
          <text class="todo-due">{{item.dueDate}}</text>
          <status-badge status="{{item.displayStatus}}" />
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-icon">
        <view class="empty-box"></view>
      </view>
      <text class="empty-text">暂无待办</text>
      <text class="empty-hint">点击右下角按钮创建</text>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="goCreate">
    <view class="fab-plus-h"></view>
    <view class="fab-plus-v"></view>
  </view>
</view>
