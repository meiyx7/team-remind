/* pages/todo-list/todo-list.wxss */

.filter-tabs {
  white-space: nowrap;
  padding: 24rpx 32rpx 16rpx;
  background: var(--bg-secondary);
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  border: 1rpx solid var(--border-light);
  background: var(--bg-primary);
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.filter-tab.active {
  background: var(--color-brand);
  color: var(--text-inverse);
  border-color: var(--color-brand);
}

.todo-list-content {
  padding: 16rpx 32rpx 200rpx;
}

.todo-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.todo-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
  padding: 32rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-left: 6rpx solid var(--color-gray-400);
  border-radius: var(--radius-md);
}

.todo-card-in_progress { border-left-color: var(--state-warning); }
.todo-card-completed { border-left-color: var(--state-success); }
.todo-card-overdue { border-left-color: var(--state-error); }

.todo-check {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--color-gray-300);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.todo-check:active {
  background: var(--bg-tertiary);
}

.todo-check.checked {
  background: var(--color-brand);
  border-color: var(--color-brand);
}

.check-icon {
  width: 16rpx;
  height: 10rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(-45deg) translate(2rpx, -2rpx);
}

.todo-main {
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.5;
}

.todo-title.done {
  text-decoration: line-through;
  color: var(--text-tertiary);
}

.todo-sub {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.todo-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.todo-due {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-box {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-gray-300);
  border-radius: 16rpx;
  position: relative;
}

.empty-box::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 28rpx;
  width: 36rpx;
  height: 20rpx;
  border-left: 6rpx solid var(--color-gray-300);
  border-bottom: 6rpx solid var(--color-gray-300);
  transform: rotate(-45deg);
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-elevated);
  z-index: 50;
}

.fab:active {
  transform: scale(0.92);
  opacity: 0.92;
}

.fab-plus-h,
.fab-plus-v {
  position: absolute;
  background: #ffffff;
  border-radius: 4rpx;
}

.fab-plus-h {
  width: 40rpx;
  height: 6rpx;
}

.fab-plus-v {
  width: 6rpx;
  height: 40rpx;
}
