/* pages/team-detail/team-detail.wxss */

.team-detail-content {
  padding: 32rpx 32rpx 80rpx;
}

/* 头部卡 */
.team-header-card {
  position: relative;
  overflow: hidden;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 32rpx;
}

.header-wash {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 192rpx;
  background: linear-gradient(135deg, var(--color-brand-lightest) 0%, transparent 70%);
  pointer-events: none;
}

.header-row {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.team-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: 40rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.team-meta {
  flex: 1;
  min-width: 0;
}

.team-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.5;
}

.team-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.stats-row {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-gray-300);
}

/* Tab */
.tab-bar {
  display: flex;
  flex-direction: row;
  margin-top: 32rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-bottom: none;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: var(--color-brand);
  border-bottom-color: var(--color-brand);
}

/* 成员列表 */
.members-list {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-top: none;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  overflow: hidden;
}

.member-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.member-row:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.member-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.member-badge {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
}

.member-badge.creator {
  background: var(--color-brand-lightest);
  color: var(--color-brand-dark);
}

.member-badge.member {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

/* 待办列表 */
.todos-pane {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-top: none;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  padding: 24rpx 32rpx;
}

.filter-tabs {
  white-space: nowrap;
  margin: 0 -8rpx 24rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  border: 1rpx solid var(--border-light);
  background: var(--bg-primary);
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.filter-tab.active {
  background: var(--color-brand);
  color: var(--text-inverse);
  border-color: var(--color-brand);
}

.todo-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.todo-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-left: 6rpx solid var(--color-gray-400);
  border-radius: var(--radius-md);
}

.todo-card-in_progress { border-left-color: var(--state-warning); }
.todo-card-completed { border-left-color: var(--state-success); }
.todo-card-overdue { border-left-color: var(--state-error); }

.todo-check {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--color-gray-300);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.todo-check.checked {
  background: var(--color-brand);
  border-color: var(--color-brand);
}

.check-icon {
  width: 16rpx;
  height: 10rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(-45deg) translate(2rpx, -2rpx);
}

.todo-main {
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.5;
}

.todo-title.done {
  text-decoration: line-through;
  color: var(--text-tertiary);
}

.todo-sub {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.todo-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.todo-due {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.empty-tip {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* 邀请按钮 */
.invite-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
  height: 96rpx;
  background: var(--color-brand);
  color: var(--text-inverse);
  border-radius: var(--radius-lg);
  font-size: 32rpx;
  font-weight: 600;
}

.invite-btn:active {
  opacity: 0.88;
}

.invite-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.invite-plus-h,
.invite-plus-v {
  position: absolute;
  background: #ffffff;
  border-radius: 2rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.invite-plus-h {
  width: 28rpx;
  height: 4rpx;
}

.invite-plus-v {
  width: 4rpx;
  height: 28rpx;
}
