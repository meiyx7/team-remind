/* pages/team-detail/team-detail.wxss */
.team-detail-content {
  padding: 32rpx 32rpx 80rpx;
}

/* 头部卡 */
.team-header-card {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 32rpx;
}

.header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.team-meta {
  flex: 1;
  min-width: 0;
}

.team-name {
  display: block;
  font-size: var(--fs-xl);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.5;
}

.team-desc {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
}

.stat-num {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}

.stat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-gray-300);
}

/* Tab */
.tab-bar {
  display: flex;
  flex-direction: row;
  margin-top: 32rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-bottom: none;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  font-size: var(--fs-base);
  font-weight: 500;
  color: var(--text-tertiary);
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: var(--color-brand);
  border-bottom-color: var(--color-brand);
}

/* 成员列表 */
.members-list {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-top: none;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  overflow: hidden;
}

.member-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.member-row:last-child {
  border-bottom: none;
}

.member-name {
  flex: 1;
  font-size: var(--fs-base);
  font-weight: 500;
  color: var(--text-primary);
}

.member-badge {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--fs-xs);
  font-weight: 500;
}

.member-badge.creator {
  background: var(--color-brand-lightest);
  color: var(--color-brand-dark);
}

.member-badge.member {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

/* 待办列表 */
.todos-pane {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-top: none;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  padding: 8rpx 32rpx 24rpx;
}

.todo-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 8rpx;
}

/* 邀请按钮（即将上线） */
.invite-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
  height: 96rpx;
  background: var(--bg-primary);
  color: var(--text-tertiary);
  border: 1rpx dashed var(--border-default);
  border-radius: var(--radius-lg);
  font-size: var(--fs-md);
  font-weight: 500;
}

.invite-btn:active {
  opacity: 0.85;
}

.invite-icon {
  width: 28rpx;
  height: 28rpx;
}
