/* pages/help/help.wxss */
.help-content {
  padding: 32rpx 32rpx 80rpx;
}

.section-title {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  margin-top: 16rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.faq-list {
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 8rpx 32rpx;
  margin-bottom: 40rpx;
}

.faq-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: block;
  font-size: var(--fs-base);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
}

.faq-a {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-top: 8rpx;
}

.feedback-input {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  font-size: var(--fs-base);
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.feedback-placeholder {
  color: var(--text-tertiary);
}

.feedback-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-brand);
  color: var(--text-inverse);
  border-radius: var(--radius-md);
  font-size: var(--fs-md);
  font-weight: 600;
  border: none;
}

.feedback-btn::after {
  border: none;
}

.contact {
  text-align: center;
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 40rpx;
}
