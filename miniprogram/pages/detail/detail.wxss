/* pages/detail/detail.wxss */

.detail-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.done-text {
  text-decoration: line-through;
  color: #999;
}

.detail-meta {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.meta-label {
  color: #999;
  font-size: 28rpx;
}

.meta-value {
  color: #333;
  font-size: 28rpx;
}

.desc-label {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.delete-btn {
  margin: 40rpx 24rpx;
  background: #e74c3c;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}
